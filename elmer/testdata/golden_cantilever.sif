Check Keywords "Warn"

Header
  Mesh DB "." "."
End

Simulation
  Coordinate Mapping(3) = Integer 1 2 3
  Coordinate System = String "Cartesian 3D"
  Max Output Level = Integer 10
  Simulation Type = String "Steady State"
  Steady State Max Iterations = Integer 1
End

Constants
  Boltzmann Constant = Real 1.380649e-23
  Gravity(4) = Real 0 -1 0 9.81
  Permeability of Vacuum = Real 1.25663706e-06
  Permittivity of Vacuum = Real 8.8542e-12
  Stefan Boltzmann = Real 5.670374419e-08
End

Body 1
  Equation = Integer 1
  Material = Integer 1
  Target Bodies(1) = Integer 1
End

Material 1
  Density = Real 7900
  Name = String "steel"
  Poisson ratio = Real 0.3
  Youngs Modulus = Real 2.1e+11
End

Equation 1
  Active Solvers(2) = Integer 1 2
End

Solver 1
  Calculate Stresses = Logical True
  Equation = String "Stress Solver"
  Linear System Abort Not Converged = Logical False
  Linear System Convergence Tolerance = Real 1e-08
  Linear System Iterative Method = String "BiCGStab"
  Linear System Max Iterations = Integer 500
  Linear System Precondition Recompute = Integer 1
  Linear System Preconditioning = String "ILU0"
  Linear System Residual Output = Integer 1
  Linear System Solver = String "Iterative"
  Optimize Bandwidth = Logical True
  Procedure = "StressSolve" "StressSolver"
  Stabilize = Logical True
  Steady State Convergence Tolerance = Real 1e-05
  Variable = String "Displacement"
  Variable DOFs = Integer 3
End

Solver 2
  Binary Output = Logical False
  Exec Solver = String "After simulation"
  Output File Name = "case"
  Procedure = "ResultOutputSolve" "ResultOutputSolver"
  Save Geometry Ids = Logical True
  Vtu Format = Logical True
End

Boundary Condition 1
  Displacement 1 = Real 0
  Displacement 2 = Real 0
  Displacement 3 = Real 0
  Target Boundaries(1) = Integer 1
End

Boundary Condition 2
  Force 1 = Real 0
  Force 2 = Real 0
  Force 3 = Real -1000
  Force 3 Normalize by Area = Logical True
  Target Boundaries(1) = Integer 2
End
